import cv2
import os
import time
import numpy as np
import face_recognition
import pyttsx3


class SmartSecuritySystem:
    def __init__(self):
        self.known_encodings = []
        self.known_names = []
        self.last_alert_time = 0
        self.alert_delay = 5
        self.engine = pyttsx3.init()
        self.engine.setProperty("rate", 150)

        self.load_known_faces()

    def load_known_faces(self):
        folder = "known_faces"

        if not os.path.exists(folder):
            print("Known faces folder not found.")
            return

        for file in os.listdir(folder):
            if file.endswith((".jpg", ".png", ".jpeg")):
                path = os.path.join(folder, file)
                image = face_recognition.load_image_file(path)
                encodings = face_recognition.face_encodings(image)

                if encodings:
                    self.known_encodings.append(encodings[0])
                    self.known_names.append(os.path.splitext(file)[0])

        print(f"{len(self.known_names)} faces loaded successfully.")

    def speak(self, message):
        self.engine.say(message)
        self.engine.runAndWait()

    def recognize(self):
        cap = cv2.VideoCapture(0)

        if not cap.isOpened():
            print("Camera not accessible.")
            return

        print("System Started... Press Q to quit.")

        while True:
            ret, frame = cap.read()
            if not ret:
                break

            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            face_locations = face_recognition.face_locations(rgb_frame)
            face_encodings = face_recognition.face_encodings(rgb_frame, face_locations)

            for (top, right, bottom, left), face_encoding in zip(face_locations, face_encodings):
                name = "Unknown"

                if self.known_encodings:
                    matches = face_recognition.compare_faces(self.known_encodings, face_encoding)
                    distances = face_recognition.face_distance(self.known_encodings, face_encoding)

                    best_match_index = np.argmin(distances)

                    if matches[best_match_index]:
                        name = self.known_names[best_match_index]

                cv2.rectangle(frame, (left, top), (right, bottom), (0, 255, 0), 2)
                cv2.putText(frame, name, (left, top - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)

                current_time = time.time()
                if current_time - self.last_alert_time > self.alert_delay:
                    if name == "Unknown":
                        self.speak("Alert! Unknown person detected.")
                    else:
                        self.speak(f"{name} identified.")

                    self.last_alert_time = current_time

            cv2.imshow("HackNovates - Smart Security", frame)

            if cv2.waitKey(1) & 0xFF == ord('q'):
                break

        cap.release()
        cv2.destroyAllWindows()


if __name__ == "__main__":
    system = SmartSecuritySystem()
    system.recognize()
